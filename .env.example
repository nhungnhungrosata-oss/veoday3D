# BACKEND PROXY MODE (khuyên dùng cho production)
# Frontend sẽ gọi /api/generate. API key nằm ở server Vercel/Railway, không đưa vào bundle browser.
# Trên Vercel/Railway, thêm các biến KHÔNG có VITE_ dưới đây trong Environment Variables.

# Google Gemini Keys - có thể nhập nhiều key free trước, key paid sau
GEMINI_API_KEY=your_free_key_here
GEMINI_API_KEY_1=your_free_key_1_here
GEMINI_API_KEY_2=your_free_key_2_here
GEMINI_API_KEY_3=your_free_key_3_here
GEMINI_API_KEY_4=your_free_key_4_here
GEMINI_API_KEY_5=your_free_key_5_here
GEMINI_API_KEY_PAID=your_paid_key_here
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek Keys - chạy sau khi toàn bộ Gemini key lỗi/hết quota/rate limit
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_API_KEY_1=sk-...
DEEPSEEK_API_KEY_2=sk-...
DEEPSEEK_MODEL=deepseek-chat

# OpenAI Keys - fallback cuối nếu DeepSeek cũng lỗi/hết tiền/hết quota
OPENAI_API_KEY=sk-...
OPENAI_API_KEY_1=sk-...
OPENAI_API_KEY_2=sk-...
OPENAI_MODEL=gpt-4o-mini

# Tuỳ chọn: tắt proxy và quay về gọi API từ browser, chỉ dùng khi test local
# VITE_USE_AI_PROXY=false

# TƯƠNG THÍCH NGƯỢC:
# Nếu bạn đã lỡ cài VITE_GEMINI_API_KEY / VITE_DEEPSEEK_API_KEY trên Vercel,
# backend proxy vẫn đọc được. Nhưng production nên đổi sang tên không có VITE_ để không lộ key trong JS bundle.
